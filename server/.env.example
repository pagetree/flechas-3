# Copy to .env and fill in values. Never commit .env.

# One connection string is enough (same as Railway DATABASE_URL)
DATABASE_URL=postgresql://postgres:your_password_here@mainline.proxy.rlwy.net:11465/railway
PGSSLMODE=require

# Admin panel
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD_HASH=

# Leave empty unless the Android app sends Bearer JWT
SIGNUP_JWT_SECRET=
